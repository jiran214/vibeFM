{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "src",
    "outDir": "dist",
    "noEmit": false,
    "incremental": false,
    "isolatedModules": false,
    "types": ["node"]
  },
  "include": ["src/cli/**/*.ts", "src/core/**/*.ts"],
  "exclude": ["src/**/*.test.ts"]
}
